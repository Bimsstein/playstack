generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

enum GameStatus {
  WANT_TO_PLAY
  PLAYING
  DONE
}

enum GameSource {
  PLAYSTATION
  STEAM
  NINTENDO
}

model Game {
  id                String     @id @default(cuid())
  userId            String?
  user              User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  source            GameSource @default(PLAYSTATION)
  psnTitleId        String?
  steamAppId        Int?
  nintendoGameId    String?
  title             String
  platform          String?
  coverUrl          String?
  currentPrice      String?
  lowestPrice30Days String?
  psnStoreRating    Float?
  wantBaselinePrice Float?
  priceAlertActive  Boolean    @default(false)
  lastAlertPrice    Float?
  lastAlertAt       DateTime?
  status            GameStatus @default(WANT_TO_PLAY)
  rating            Int?
  trophyCompletion  Int?
  earnedTrophies    Int?
  totalTrophies     Int?
  storyPlusHours    Int?
  lastSyncedAt      DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  notifications     Notification[]

  @@index([userId, status, updatedAt])
  @@unique([userId, psnTitleId])
  @@unique([userId, steamAppId])
  @@unique([userId, nintendoGameId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String?
  title     String
  message   String
  createdAt DateTime @default(now())
  readAt    DateTime?
  game      Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([gameId])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PsnLibraryTitle {
  id               String   @id @default(cuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  psnTitleId       String
  title            String
  platform         String?
  coverUrl         String?
  trophyCompletion Int?
  earnedTrophies   Int?
  totalTrophies    Int?
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, psnTitleId])
  @@index([userId, updatedAt])
}

model SteamLibraryTitle {
  id               String   @id @default(cuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  steamAppId       Int
  title            String
  platform         String?
  coverUrl         String?
  playtimeHours    Int?
  trophyCompletion Int?
  earnedTrophies   Int?
  totalTrophies    Int?
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, steamAppId])
  @@index([userId, updatedAt])
}

model NintendoLibraryTitle {
  id                String   @id @default(cuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  nintendoGameId    String
  title             String
  platform          String?
  coverUrl          String?
  currentPrice      String?
  lowestPrice30Days String?
  releaseDate       String?
  trophyCompletion  Int?
  earnedTrophies    Int?
  totalTrophies     Int?
  lastSyncedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, nintendoGameId])
  @@index([userId, updatedAt])
}

model User {
  id           String                @id @default(cuid())
  email        String                @unique
  passwordHash String
  displayName  String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  sessions     Session[]
  games        Game[]
  notifications Notification[]
  psnLibrary   PsnLibraryTitle[]
  steamLibrary SteamLibraryTitle[]
  nintendoLibrary NintendoLibraryTitle[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}
